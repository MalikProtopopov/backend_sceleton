# =============================================================================
# Caddy reverse proxy for Mediann multi-tenant platform
# Docker deployment: Caddy and backend are in the same Docker network.
# Backend is accessible as "backend:8000" inside the network.
# =============================================================================

{
	email ssl@mediann.dev

	# Before issuing a certificate for any domain, Caddy asks FastAPI
	# whether this domain is allowed. Returns 200 = issue cert, 403 = deny.
	on_demand_tls {
		ask http://backend:8000/internal/domains/check
		interval 2m
		burst 5
	}
}

# ---------------------------------------------------------------------------
# All domains — on-demand TLS (Let's Encrypt HTTP-01 challenge)
# Covers: *.mediann.dev subdomains AND custom tenant domains
# ---------------------------------------------------------------------------
:443 {
	tls {
		on_demand
	}

	reverse_proxy backend:8000 {
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-Proto {scheme}
	}
}

# ---------------------------------------------------------------------------
# HTTP → HTTPS redirect
# ---------------------------------------------------------------------------
:80 {
	redir https://{host}{uri} permanent
}
