# =============================================================================
# Caddy reverse proxy for Mediann multi-tenant platform
# Docker deployment: Caddy and backend are in the same Docker network.
# Backend (FastAPI) is accessible as "backend:8000" inside the network.
# Admin panel (Next.js) is accessible as "admin:3000" inside the network.
# =============================================================================

{
	email ssl@mediann.dev

	# Before issuing a certificate for any unknown domain, Caddy asks FastAPI
	# whether this domain is allowed. Returns 200 = issue cert, 403 = deny.
	on_demand_tls {
		ask http://backend:8000/internal/domains/check
	}
}

# ---------------------------------------------------------------------------
# FastAPI backend API (api.mediann.dev)
# ---------------------------------------------------------------------------
api.mediann.dev {
	reverse_proxy backend:8000 {
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-Proto {scheme}
	}
}

# ---------------------------------------------------------------------------
# Platform admin panel (admin.mediann.dev) → Next.js
# ---------------------------------------------------------------------------
admin.mediann.dev {
	reverse_proxy admin:3000 {
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-Proto {scheme}
	}
}

# ---------------------------------------------------------------------------
# Custom tenant domains (admin.yastvo.com, etc.) — on-demand TLS
# All custom domains route to the same Next.js admin, which detects
# the hostname and shows the appropriate tenant's panel.
# ---------------------------------------------------------------------------
:443 {
	tls {
		on_demand
	}

	reverse_proxy admin:3000 {
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-Proto {scheme}
	}
}

# ---------------------------------------------------------------------------
# HTTP → HTTPS redirect
# ---------------------------------------------------------------------------
:80 {
	redir https://{host}{uri} permanent
}
